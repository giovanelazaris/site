head
  meta(charset='utf-8')
  title Adicionar Cliente
  link(rel='stylesheet', href='https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0-alpha.2/css/bootstrap.min.css')

  body
    p 
    .modal-dialog
        .modal-content
          // Modal Header
          // Modal Body
          .modal-body
            //#editForm.form(role='form' method='GET' action='https://www.google.com/')
            form(role='form', method='POST', action='/edit/' + clients.id)
              div.form-group
                label(for='name') Nome:
                input#name.form-control(type='text', placeholder='nome' name='nome' value=clients.nome)
              div.form-group
                label(for='email') Email:
                input#email.form-control(type='email', placeholder='nome@email.com' name='email' value=clients.email)
              button.btn.btn-primary(type="submit", name="asdf") Adicionar Cliente 